# ── Credit Scoring Application Configuration ──
# Copy this file to .env and adjust values as needed.

# Networking
BENTOML_PORT=3000
STREAMLIT_PORT=8501
API_URL=http://localhost:3000
API_TIMEOUT=30

# Model
MODEL_TAG=credit_scoring:latest

# Data paths
DATA_DIR=./data

# Excel file names (relative to DATA_DIR)
CUSTOMERS_FILE=customer_profiles_5000.xlsx
LOANS_FILE=loan_history_5000.xlsx
TRANSACTIONS_FILE=transaction_history_5000.xlsx

# Virtual environment
VENV_PATH=../.venv
